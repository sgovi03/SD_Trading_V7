# ==================================================================
# SD TRADING V8 — MASTER CONFIG
# config/MASTER.config
#
# This is the root of the three-tier config cascade:
#   MASTER.config (this file)     → all parameters + defaults
#   classes/{ASSET_CLASS}.config  → asset-class overrides
#   symbols/{SYMBOL}.config       → symbol-specific overrides
#
# Rules:
#   1. ALL parameters must be defined here with safe defaults
#   2. Class and symbol configs only contain what they override
#   3. This file is read first; later tiers layer on top
#   4. Do not put symbol-specific values (lot_size, etc.) here
#
# Migrated from: conf/phase_6_config_v0_7.txt (V7 working config)
# All values below match the V7 production config exactly.
# Override at class or symbol level only if needed.
# ==================================================================


# ------------------------------------------------------------------
# CAPITAL & RISK
# ------------------------------------------------------------------

starting_capital                    = 300000
risk_per_trade_pct                  = 1.0
commission_per_trade                = 20.0
max_loss_per_trade                  = 1500.0
max_fill_slippage_pts               = 25.0


# ------------------------------------------------------------------
# ZONE DETECTION (Backtest + Live shared)
# ------------------------------------------------------------------

base_height_max_atr                 = 1.9
consolidation_min_bars              = 2
consolidation_max_bars              = 55
min_impulse_atr                     = 0.18
min_zone_width_atr                  = 0.705
min_zone_strength                   = 63.5
atr_period                          = 14
only_fresh_zones                    = NO
invalidate_on_body_close            = NO
gap_over_invalidation               = NO
skip_retest_after_gap_over          = NO

# Zone age filtering
min_zone_age_days                   = 0
max_zone_age_days                   = 60
max_touch_count                     = 200

# Zone state
skip_violated_zones                 = YES
skip_tested_zones                   = NO
prefer_fresh_zones                  = YES


# ------------------------------------------------------------------
# DUPLICATE PREVENTION & MERGING
# ------------------------------------------------------------------

duplicate_prevention_enabled        = YES
zone_existence_tolerance_atr        = 1.0
atr_buffer_multiplier               = 2.30
check_existing_before_create        = YES
merge_strategy                      = update_if_stronger
strength_improvement_threshold      = 10.0
freshness_bars_threshold            = 30
zone_detection_interval_bars        = 6


# ------------------------------------------------------------------
# ELITE ZONE CRITERIA
# ------------------------------------------------------------------

min_departure_imbalance             = 2.0
max_retest_speed_atr                = 1.5
min_bars_to_retest                  = 10


# ------------------------------------------------------------------
# SWEEP & RECLAIM
# ------------------------------------------------------------------

enable_sweep_reclaim                = NO
reclaim_acceptance_bars             = 2
reclaim_acceptance_pct              = 0.5


# ------------------------------------------------------------------
# ZONE FLIP DETECTION
# ------------------------------------------------------------------

enable_zone_flip                    = NO
flip_min_impulse_atr                = 1.5
flip_lookback_bars                  = 10


# ------------------------------------------------------------------
# SCORING — ADAPTIVE ENTRY
# ------------------------------------------------------------------

use_adaptive_entry                  = YES
high_score_position_mult            = 1.0
high_score_threshold                = 65.0

# Two-stage scoring
enable_two_stage_scoring            = NO
enable_revamped_scoring             = NO


# ------------------------------------------------------------------
# EMA TREND FILTER
# ------------------------------------------------------------------

use_ema_trend_filter                = YES
ema_fast_period                     = 9
ema_slow_period                     = 21
ema_ranging_threshold_pct           = 1.0
require_ema_alignment_for_longs     = YES
require_ema_alignment_for_shorts    = YES
ema_min_separation_pct_long         = 0.1
ema_min_separation_pct_short        = 0.1


# ------------------------------------------------------------------
# TRAILING STOP
# ------------------------------------------------------------------

use_trailing_stop                   = YES
trail_activation_rr                 = 0.550
trailing_stop_activation_r          = 0.9
trail_atr_multiplier                = 2.0
trail_ema_period                    = 20
trail_ema_buffer_pct                = 0.2
trail_use_hybrid                    = YES
trail_fallback_tp_rr                = 5.0


# ------------------------------------------------------------------
# STOP LOSS & TAKE PROFIT
# ------------------------------------------------------------------

stop_loss_atr_multiplier            = 1.2
target_rr_ratio                     = 1.75
sl_buffer_zone_pct                  = 0.1
sl_buffer_atr                       = 0.1
rejection_wick_ratio                = 0.4
entry_buffer_pct                    = 0.1
min_stop_distance_points            = 0.0
use_breakeven_stop_loss             = NO


# ------------------------------------------------------------------
# LIVE FILL QUALITY GUARDS
# ------------------------------------------------------------------

min_zone_penetration_pct            = 0.20
require_price_at_entry_level        = NO


# ------------------------------------------------------------------
# TRADE MANAGEMENT
# ------------------------------------------------------------------

max_concurrent_trades               = 1
max_consecutive_losses              = 4
pause_bars_after_losses             = 80
lookback_for_zones                  = 100
max_retries_per_zone                = 2
enable_per_zone_retry_limit         = NO


# ------------------------------------------------------------------
# SESSION MANAGEMENT
# ------------------------------------------------------------------

close_eod                           = YES
session_end_time                    = 15:30
close_before_session_end_minutes    = 0


# ------------------------------------------------------------------
# ENTRY TIME BLOCK
# ------------------------------------------------------------------

enable_entry_time_block             = YES
entry_block_start_time              = 09:15
entry_block_end_time                = 09:45


# ------------------------------------------------------------------
# CANDLE & STRUCTURE CONFIRMATION (LIVE)
# ------------------------------------------------------------------

enable_candle_confirmation          = NO
candle_confirmation_body_pct        = 35.0
enable_structure_confirmation       = NO


# ------------------------------------------------------------------
# HTF REGIME FILTER
# ------------------------------------------------------------------

use_htf_regime_filter               = YES
htf_lookback_bars                   = 700
htf_trending_threshold              = 5.0


# ------------------------------------------------------------------
# SWING ANALYSIS
# ------------------------------------------------------------------

swing_detection_bars                = 20
trade_with_trend_only               = YES
allow_ranging_trades                = YES
use_bos_trend_filter                = NO


# ------------------------------------------------------------------
# LIVE ENGINE SETTINGS
# ------------------------------------------------------------------

use_relaxed_live_detection          = YES
live_zone_detection_interval_bars   = 1
live_zone_detection_lookback_bars   = 200
live_min_zone_width_atr             = 0.705
live_min_zone_strength              = 63.5
live_entry_require_new_bar          = YES
live_skip_when_in_position          = YES
live_zone_entry_cooldown_seconds    = 60


# ------------------------------------------------------------------
# LIVE ZONE FILTERING (range-based)
# ------------------------------------------------------------------

enable_live_zone_filtering          = NO
live_zone_range_pct                 = 5.0
live_zone_refresh_interval_minutes  = 30
max_zone_distance_atr               = 1000


# ------------------------------------------------------------------
# ZONE BOOTSTRAP (startup zone generation)
# ------------------------------------------------------------------

zone_bootstrap_enabled              = YES
zone_bootstrap_ttl_hours            = 24
zone_bootstrap_refresh_time         = 08:50
zone_bootstrap_force_regenerate     = YES


# ------------------------------------------------------------------
# V6.0 — VOLUME ANALYSIS
# ------------------------------------------------------------------

enable_volume_entry_filters         = NO
enable_volume_exit_signals          = NO
enable_volume_exhaustion_exit       = NO
min_entry_volume_ratio              = 0.8
institutional_volume_threshold      = 2.0
extreme_volume_threshold            = 3.0
volume_lookback_period              = 20
volume_normalization_method         = time_of_day
volume_baseline_file                = data/baselines/volume_baseline_5min.json

# Volume exit signals
volume_climax_exit_threshold        = 3.0
volume_drying_up_threshold          = 0.5
volume_drying_up_bar_count          = 3
enable_volume_divergence_exit       = YES

# Volume pattern filters (entry)
max_entry_volume_ratio              = 3.0
max_volume_without_elite            = 2.0
min_inst_for_high_volume            = 60.0
optimal_volume_min                  = 1.0
optimal_volume_max                  = 2.0
optimal_institutional_min           = 45.0
allow_low_volume_if_score_above     = 65.0
elite_institutional_threshold       = 70.0
min_volume_entry_score              = 10


# ------------------------------------------------------------------
# V6.0 — OI ANALYSIS
# ------------------------------------------------------------------

enable_oi_entry_filters             = YES
enable_oi_exit_signals              = YES
enable_market_phase_detection       = YES
min_oi_change_threshold             = 0.01
high_oi_buildup_threshold           = 0.05
oi_lookback_period                  = 10
price_oi_correlation_window         = 10.0

# OI exit signals
oi_unwinding_threshold              = -0.01
oi_reversal_threshold               = 0.02
oi_stagnation_threshold             = 0.005
oi_stagnation_bar_count             = 10


# ------------------------------------------------------------------
# V6.0 — SCORING WEIGHTS (Volume + OI)
# ------------------------------------------------------------------

base_score_weight                   = 0.50
volume_score_weight                 = 0.30
oi_score_weight                     = 0.20
institutional_volume_bonus          = 30.0
oi_alignment_bonus                  = 25.0
low_volume_retest_bonus             = 20.0


# ------------------------------------------------------------------
# V6.0 — DYNAMIC POSITION SIZING
# ------------------------------------------------------------------

low_volume_size_multiplier          = 0.5
high_institutional_size_mult        = 1.5
max_lot_size                        = 650


# ------------------------------------------------------------------
# V6.0 — EXPIRY DAY HANDLING
# ------------------------------------------------------------------

trade_on_expiry_day                 = YES
expiry_day_disable_oi_filters       = YES
expiry_day_position_multiplier      = 0.5
expiry_day_min_zone_score           = 75.0


# ------------------------------------------------------------------
# V6.0 — FEATURE FLAGS
# ------------------------------------------------------------------

v6_fully_enabled                    = YES
v6_log_volume_filters               = NO
v6_log_oi_filters                   = NO
v6_log_institutional_index          = NO
v6_validate_baseline_on_startup     = YES


# ------------------------------------------------------------------
# INDICATOR PERIODS (for trade log / reporting)
# ------------------------------------------------------------------

rsi_period                          = 14
bb_period                           = 20
bb_stddev                           = 2.0
adx_period                          = 14
macd_fast_period                    = 12
macd_slow_period                    = 26
macd_signal_period                  = 9

# EMA exit periods (LIVE)
enable_ema_exit                     = YES
exit_ema_fast_period                = 9
exit_ema_slow_period                = 20


# ------------------------------------------------------------------
# ZONE EXHAUSTION
# ------------------------------------------------------------------

zone_consecutive_loss_max           = 2


# ------------------------------------------------------------------
# LOGGING & DEBUG
# ------------------------------------------------------------------

enable_debug_logging                = NO
enable_score_logging                = NO
live_export_every_n_bars            = 0


# ------------------------------------------------------------------
# STATE HISTORY
# ------------------------------------------------------------------

enable_state_history                = NO
max_state_history_events            = 100
record_zone_creation                = YES
record_first_touch                  = YES
record_retests                      = YES
record_violations                   = YES


# ------------------------------------------------------------------
# SCANNER (V8 — multi-symbol scanner settings)
# ------------------------------------------------------------------

scanner_mode                        = NO
scanner_signal_min_score            = 65.0
scanner_rank_by                     = SCORE


# ------------------------------------------------------------------
# COMPUTE BACKEND (V8 — GPU/CPU selection)
# ------------------------------------------------------------------

compute_backend                     = AUTO
cpu_thread_pool_size                = 8
cuda_device_id                      = 0
cuda_min_symbols_threshold          = 20


# ==================================================================
# END OF MASTER CONFIG
# ==================================================================
