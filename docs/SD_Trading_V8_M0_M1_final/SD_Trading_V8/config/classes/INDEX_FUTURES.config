# ==================================================================
# SD TRADING V8 — CLASS CONFIG: INDEX_FUTURES
# config/classes/INDEX_FUTURES.config
#
# Applies to: NIFTY, BANKNIFTY, FINNIFTY, MIDCPNIFTY
#
# Contains ONLY parameters that differ from MASTER.config
# for index futures as an asset class.
# All other parameters are inherited from MASTER.config.
#
# Cascade order: MASTER → this file → symbols/{SYMBOL}.config
# ==================================================================

# Index futures are more volatile — slightly wider SL buffer
sl_buffer_atr                       = 0.15

# Index futures have reliable OI data — enable OI filters
enable_oi_entry_filters             = YES
enable_oi_exit_signals              = YES
enable_market_phase_detection       = YES

# Expiry day: index futures expire on last Thursday of month
# (overridden per-symbol for BANKNIFTY which is Wednesday)
trade_on_expiry_day                 = YES
expiry_day_disable_oi_filters       = YES

# Volume baseline is per-instrument — override at symbol level
# volume_baseline_file              = (set in symbol config)
