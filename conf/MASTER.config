# ============================================================================
# ZONE AGE AND STATE FILTERING - CRITICAL FIX FOR RUN 2 ISSUE
# ============================================================================
# Run 2 analysis showed:
# - 16 trades on VIOLATED zones in Nov-Feb → Lost ₹30,773
# - 25 trades on zones >60 days old → Massive losses
# These filters prevent trading stale/violated zones

min_zone_age_days = 0           # Minimum zone age (0 = can trade fresh zones)
max_zone_age_days = 390          # ⭐ CRITICAL: Maximum 60 days (changed from 980!)
                                # Prevents trading stale zones that lost money in Run 2

# [REMOVED DUPLICATE of line 88]: exclude_zone_age_range = NO     # Disable complex age range exclusion (not needed)
# [REMOVED DUPLICATE of line 89]: exclude_zone_age_start = 30     # (ignored when exclude_zone_age_range = NO)

# ⭐ CRITICAL: Zone State Filtering (NEW - fixes Run 2 issue)
skip_violated_zones = YES       # Don't trade VIOLATED zones (MANDATORY!)
skip_tested_zones = NO          # Can trade TESTED zones (they perform OK)
prefer_fresh_zones = YES        # Prefer FRESH but don't reject TESTED
# ============================================================================

use_adaptive_entry = YES
entry_minimum_score = 30.0
entry_optimal_score = 78.0
max_retries_per_zone = 20
rr_max_ratio = 2.99
trail_fallback_tp_rr = 2.99
max_loss_per_trade = 56600.0
min_entry_sl_points = 20          # Reject entries with SL < 20 pts (post-TRAIL_SL re-entries)
sl_buffer_zone_pct = 1.0
sl_buffer_atr = 0.5
min_stop_distance_points = 65
trail_ema_buffer_pct = 0.1

max_fill_slippage_pts = 2.0
zone_max_age_days = 390
