# ============================================================================
# ⭐ NEW FILTERS — from live trade analysis (March 2026)
# ============================================================================

# Priority 1: Zone consecutive-loss exhaustion
# After zone_consecutive_loss_max SL losses from the same zone, mark it EXHAUSTED.
# Prevents re-entering a "burnt" zone until a TP win resets it.
# Evidence: Zone 25 = -₹25,455 (2 stops); Zone 9 = -₹10,215 (2 stops).
enable_zone_exhaustion    = YES
zone_consecutive_loss_max = 2    # Block after 2nd consecutive SL loss
zone_sl_suspend_threshold       =   3      # SL hits per direction before suspension (0=disabled)

# Priority 2: ADX transition-zone position size reduction
# ADX 40-60 = only net-negative ADX band: 9 trades, avg -₹9,236 P&L.
# Default: trade at half size. Set adx_transition_skip_entry=YES to skip entirely.
enable_adx_transition_filter = YES
adx_transition_min           = 55.0
adx_transition_max           = 999.0
adx_transition_size_factor   = 0.5   # Half position in danger band
adx_transition_skip_entry    = YES    # NO=half-size; YES=skip entry entirely

# Priority 3: Late-session entry cutoff
# No new entries at or after this time. Trade #1719 (15:05) lost -₹9,274 in 1 bar.
# Start conservative then tune based on live results.
enable_late_entry_cutoff = YES
late_entry_cutoff_time   = 14:30  # No new entries after 2:30 PM

# Priority 4: Hard cap on position lots
# 6-lot trade = -₹16,164 (worst). 4-lot trades = 78% WR, avg +₹12,326.
# Applied AFTER max_loss_per_trade has already reduced size — absolute ceiling.
max_position_lots = 2
max_touch_count = 40;

enable_rsi_hard_block = YES
rsi_hard_block_high = 72.0    # lower from 72 to 65
rsi_hard_block_low  = 28.0 

# ============================================================
# BAR VALIDATOR SETTINGS — add this block to MASTER.config
# ============================================================

# Master switch: YES = full validation, NO = tier-1 only (structural checks)
# When NO, nothing is written to bar_rejections table.
bar_validation_enabled = NO

# Tier-1 structural checks switch: YES = enforce H/L/O/C/volume/timestamp sanity,
# NO = bypass tier-1 checks too.
bar_validation_tier1_structural_enabled = NO

# Max overnight gap between consecutive bars (open vs prev close %).
# 5.0 covers the Feb 2026 tariff shock (4.2% genuine gap).
# Old default of 3.0 caused 2,027 false rejections of Sep data.
bar_validation_max_gap_pct = 5.0

# Max (High-Low) / rolling ATR multiple.
# 6x handles 09:15 opening auction bars (routinely show 5-10x ATR).
bar_validation_atr_spike = 6.0

# Max bar volume / rolling average volume.
# 20x handles new contract months where the 20-bar avg is near zero.
bar_validation_vol_spike = 20.0

# Max |OI change| / prev OI percentage.
# 50% handles contract rollover days (NIFTY monthly rolls cause 100-350% jumps).
bar_validation_oi_spike = 50.0

# Skip all tier-2 checks for the first bar of each trading day (09:15).
# Opening auction bars have wide spread and spike ATR — real price discovery.
bar_validation_skip_09_15 = YES

# Minimum bar history required before volume spike check activates.
# New contracts start with avg_volume ≈ 0; require 50 bars (~4 hours) first.
bar_validation_vol_min_bars = 50
zone_bootstrap_force_regenerate = NO