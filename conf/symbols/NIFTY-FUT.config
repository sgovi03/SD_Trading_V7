# ==================================================================
# SD TRADING V8 — SYMBOL CONFIG: NIFTY
# config/symbols/NIFTY.config
#
# Symbol: NIFTY (Nifty 50 Futures)
# Asset class: INDEX_FUTURES
# Exchange: NSE
# Lot size: 75 (as of Apr 2025; update when NSE changes it)
# Expiry: Last Thursday of month
#
# Contains ONLY parameters that differ from:
#   MASTER.config → classes/INDEX_FUTURES.config → THIS FILE
#
# DO NOT duplicate parameters that are already correct in
# MASTER.config or INDEX_FUTURES.config.
# ==================================================================

# Symbol identity (used for logging and file naming)
# Note: lot_size is also in symbol_registry — registry wins.
# This entry is kept for documentation and fallback only.
 lot_size                          = 65

# NIFTY-specific volume baseline file
volume_baseline_file                = data/baselines/NIFTY_FUT_volume_baseline_5min.json

# NIFTY tick size is 0.05 — affects min stop distance
# (tick_size comes from symbol_registry, not config)

# NIFTY-specific zone parameters tuned from live trade analysis
# These are the V7 production-validated values:
# min_zone_width_atr                  = 0.705
# live_min_zone_width_atr             = 0.705
# min_zone_strength                   = 63.5
# live_min_zone_strength              = 63.5

# ==================================================================
# SD TRADING V8 — SYMBOL CONFIG: NIFTY
# config/symbols/NIFTY.config
#
# Symbol: NIFTY (Nifty 50 Futures)
# Asset class: INDEX_FUTURES
# Exchange: NSE
# Lot size: 75 (as of Apr 2025; update when NSE changes it)
# Expiry: Last Thursday of month
#
# Contains ONLY parameters that differ from:
#   MASTER.config → classes/INDEX_FUTURES.config → THIS FILE
# ==================================================================

 lot_size                          = 65

volume_baseline_file                = data/baselines/NIFTY_FUT_volume_baseline_5min.json

# ==================================================================
# ENTRY FILTERS — validated on 124 NIFTY trades (Sep 2025–Apr 2026)
# ==================================================================

# MACD Momentum filter — direction-aware (already delivered, confirmed ±82k gain)
# LONG  rejected if MACD Histogram < -15 (downward momentum dominates)
# SHORT rejected if MACD Histogram > +15 (upward momentum dominates)
enable_macd_histogram_filter = YES
macd_histogram_threshold     = 15.0

# 11AM midday chop block — HIGHEST impact per trade eliminated (+₹3,189/trade)
# 11AM hour: WR=25.9% (7W/20L), P&L=-₹86,097 on NIFTY. Structural, not random.
# Also confirmed on BankNifty: identical 25.9% WR at same hour.
enable_entry_block2          = YES
entry_block2_start_time      = 11:00
entry_block2_end_time        = 12:00

# Bollinger Bandwidth filter — require market expansion before entry
# Sweet spot [0.60, 1.00): WR=41.4%, P&L=+₹21,632 vs baseline -₹60,467
# Below 0.60 = compression/chop. Above 1.00 = overextended, no room to run.
# NOTE: This reduces trade count significantly (to ~29 trades over 8 months)
#       Enable only if you can tolerate lower frequency.
#       Recommended to enable AFTER validating MACD+11AM in live first.
enable_bb_bandwidth_filter   = NO   # start disabled; enable after MACD+11AM proven
bb_bandwidth_min             = 0.60
bb_bandwidth_max             = 1.00

# Zone score cap — NOT recommended for NIFTY
# NIFTY score 30-39 is only marginally positive (+₹5.6k), unlike BankNifty (+₹84k).
# MACD+11AM already eliminates the worst high-score trades.
# zone_quality_maximum_score = 0.0   # disabled (0 = off)

# ==================================================================
# END OF NIFTY SYMBOL CONFIG
# ==================================================================