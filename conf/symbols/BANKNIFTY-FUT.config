# BankNifty is more volatile than NIFTY:
# wider zones, slightly more lenient thresholds
# min_zone_width_atr                  = 0.65
# live_min_zone_width_atr             = 0.65
# min_zone_strength                   = 60.0
# live_min_zone_strength              = 60.0

# BankNifty-specific volume baseline
volume_baseline_file                = data/baselines/BANKNIFTY_FUT_volume_baseline_5min.json

# BankNifty lot size (also in symbol_registry — kept here for reference)
lot_size                          = 30

