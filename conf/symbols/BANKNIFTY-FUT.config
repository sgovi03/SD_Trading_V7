# ==================================================================
# SD TRADING V8 — SYMBOL CONFIG: BANKNIFTY
# config/symbols/BANKNIFTY.config
#
# Symbol: BANKNIFTY (Bank Nifty Futures)
# Asset class: INDEX_FUTURES
# Exchange: NSE
# Lot size: 15 (as of Apr 2025)
# Expiry: Last Wednesday of month (differs from NIFTY Thursday)
#
# Contains ONLY parameters that differ from:
#   MASTER.config → classes/INDEX_FUTURES.config → THIS FILE
# ==================================================================

# BankNifty is more volatile than NIFTY:
# wider zones, slightly more lenient thresholds
# min_zone_width_atr                  = 0.65
# live_min_zone_width_atr             = 0.65
# min_zone_strength                   = 60.0
# live_min_zone_strength              = 60.0

# BankNifty-specific volume baseline
volume_baseline_file                = data/baselines/BANKNIFTY_FUT_volume_baseline_5min.json

# BankNifty lot size (also in symbol_registry — kept here for reference)
lot_size                          = 30

# ==================================================================
# END OF BANKNIFTY SYMBOL CONFIG
# ==================================================================
# ── POSITION SIZING — THE CRITICAL FIX ─────────────────────────────
# BankNifty ₹30/pt vs Nifty ₹75/pt. Same max_loss gives 3× more lots.
# Cap to 2 lots maximum at 95-pt SL.
max_loss_per_trade        = 8000     # was 19600 — simulation: -76k → +56k
max_position_lots         = 2        # hard ceiling regardless of formula

# ── ENTRY QUALITY — PVR GATE ────────────────────────────────────────
# PVR 0.5–0.8 is the single worst bucket (WR=32%, -₹209k).
# Only take entries on genuinely weak pullbacks.
entry_score_volume_entry_min = 45    # was 35 — filters medium-PVR entries

# ── DIRECTION BIAS — LONGS STRUCTURALLY BROKEN ─────────────────────
# LONG: WR=38%, -₹143k. SHORT: WR=43%, +₹66k.
# Require higher score threshold for long entries.
entry_minimum_score       = 40.0     # was 30.0

# ── ZONE DETECTION — WIDER INSTRUMENT ──────────────────────────────
# BankNifty avg zone width = 59pts (vs Nifty 26pts = 2.3× wider).
# ATR-based parameters already handle this correctly.
# No change needed — zone detection is fine.

# ── REGIME FILTER ───────────────────────────────────────────────────
# TRENDING regime: WR=39%, -₹111k. Skip trending entries.
adx_transition_min        = 35.0     # was 55.0 — broader block
adx_transition_skip_entry = YES      # skip rather than reduce size
# ==================================================================
# SD TRADING V8 — SYMBOL CONFIG: BANKNIFTY
# config/symbols/BANKNIFTY.config
#
# Symbol: BANKNIFTY (Bank Nifty Futures)
# Asset class: INDEX_FUTURES
# Exchange: NSE
# Lot size: 15 (as of Apr 2025)
# Expiry: Last Wednesday of month (differs from NIFTY Thursday)
# ==================================================================

lot_size                          = 30
volume_baseline_file              = data/baselines/BANKNIFTY_FUT_volume_baseline_5min.json

# ==================================================================
# POSITION SIZING — CRITICAL (₹30/pt vs Nifty ₹75/pt)
# Same max_loss_per_trade gives 3× more lots on BankNifty → 3× more exposure
# ==================================================================
# max_loss_per_trade        = 58000    # was 19600; eliminates 20 SL trades losing -₹400k
# max_position_lots         = 6       # hard ceiling: never more than 2 lots

# ==================================================================
# ENTRY QUALITY
# ==================================================================
entry_score_volume_entry_min = 45   # was 35; PVR 0.5-0.8 bucket (-₹209k) filtered out
entry_minimum_score          = 40.0 # was 30.0; LONG trades structurally weak (WR=38%)

# ==================================================================
# REGIME FILTER
# ==================================================================
adx_transition_min        = 35.0    # was 55.0; broader trending block
adx_transition_skip_entry = YES     # skip rather than reduce size

# ==================================================================
# MACD MOMENTUM FILTER — highest per-trade impact on BankNifty (+₹3,458/trade)
# ==================================================================
enable_macd_histogram_filter = YES
macd_histogram_threshold     = 15.0

# ==================================================================
# 11AM MIDDAY CHOP BLOCK — strongest absolute gain (+₹247k, +₹9,154/trade)
# 11AM hour: WR=25.9% (7W/20L), P&L=-₹247,162. Worst single hour by far.
# ==================================================================
enable_entry_block2          = YES
entry_block2_start_time      = 11:00
entry_block2_end_time        = 12:00

# ==================================================================
# ZONE SCORE CAP — BankNifty specific (score paradox is pronounced here)
# Score 30-39: WR=54%, +₹84k. Score 40+: WR≤33%, all negative.
# High scores = obvious retail levels swept by institutions on volatile BankNifty.
# ==================================================================
zone_quality_maximum_score   = 49.0  # reject zones scoring above 49

# ==================================================================
# BOLLINGER BANDWIDTH — require market expansion
# Sweet spot [0.60, 1.00): WR=41.4%, +₹87,760
# ==================================================================
enable_bb_bandwidth_filter   = NO    # start disabled; enable after core filters proven
bb_bandwidth_min             = 0.60
bb_bandwidth_max             = 1.00

# ==================================================================
# END OF BANKNIFTY SYMBOL CONFIG
# ==================================================================